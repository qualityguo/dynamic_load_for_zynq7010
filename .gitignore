# =====================================================================
# Vitis / Xilinx SDK / Eclipse 工作区 .gitignore
# 仓库根目录: D:\RTOS_Study\ssbl
# =====================================================================

# ---------- Eclipse / Vitis 工作区元数据（机器相关，可重新生成）----------
.metadata/
RemoteSystemsTempFiles/
.recommenders/
.lock
*.lock

# ---------- Vivado / Vitis 临时与日志 ----------
Packages/
.Xil/
*.log
*.jou
*.str
*.pb
*.wdb
*.bak
*.tmp

# ---------- 构建输出目录 ----------
Debug/
Release/
**/Debug/
**/Release/

# ---------- 编译中间产物 ----------
*.o
*.obj
*.d
*.a
*.lib
*.slo
*.lo

# ---------- 链接 / 烧录产物（如需版本管理请注释掉对应行）----------
*.elf
*.bin
*.map
*.lst
*.dump
*.mif

# ---------- 平台导出目录（Vitis 每次构建会重新生成）----------
**/export/

# ---------- 其它 ----------
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------ Xilinx / Vivado / Vitis 额外忽略 ------------------
# 常见生成文件与平台导出 (bitstream, hardware archive, platform)
*.bit
*.bin
*.bif
*.hdf
*.xsa
*.xpr
*.xci
*.dcp

# Vivado runs / project dirs / intermediate build folders
.run/
*.runs/
*.cache/
*.implement/

# 项目 / IDE 元文件（可根据需要保留）
.project
.cproject
.settings/
.vscode/
*.launch

# Xilinx / SDK / BSP 及生成清单
Xilinx.spec
*.elf.size
*.md5
*.bsp
BSP/

# 常见 autogenerated files
_ide/
psinit/
bitstream/
hwspec.checksum
*.bit

# Makefile / build artifacts (已在上方部分覆盖通配符)
objects.mk
sources.mk
makefile

# 保留：如果你希望版本管理某些生成物，请注释掉对应行。
